{
  "manifest_version": 3,
  "name": "JobAutoApply - AI Job Application Automation",
  "version": "1.0.0",
  "description": "Scrape, autofill, and auto-apply to jobs on LinkedIn, Indeed, Greenhouse, Lever, Workday, iCIMS, Workable, JobRight, WTTJ, Glassdoor & more. AI-powered captcha bypass included.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs",
    "alarms",
    "notifications",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://indeed.com/*",
    "https://www.indeed.com/*",
    "https://greenhouse.io/*",
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.workday.com/*",
    "https://*.icims.com/*",
    "https://*.workable.com/*",
    "https://apply.workable.com/*",
    "https://jobright.ai/*",
    "https://www.welcometothejungle.com/*",
    "https://www.glassdoor.com/*",
    "https://www.glassdoor.co.uk/*",
    "https://weworkremotely.com/*",
    "https://remoteok.com/*",
    "https://angel.co/*",
    "https://wellfound.com/*",
    "https://jobs.ashbyhq.com/*",
    "https://*.ashbyhq.com/*",
    "https://boards.greenhouse.io/*",
    "https://jobs.recruitee.com/*",
    "https://*.recruitee.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content-scripts/linkedin.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://indeed.com/*", "https://www.indeed.com/*"],
      "js": ["content-scripts/indeed.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://boards.greenhouse.io/*",
        "https://greenhouse.io/*"
      ],
      "js": ["content-scripts/greenhouse.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jobs.lever.co/*", "https://*.lever.co/*"],
      "js": ["content-scripts/lever.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.myworkdayjobs.com/*", "https://*.workday.com/*"],
      "js": ["content-scripts/workday.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.icims.com/*"],
      "js": ["content-scripts/icims.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://apply.workable.com/*", "https://*.workable.com/*"],
      "js": ["content-scripts/workable.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://jobright.ai/*"],
      "js": ["content-scripts/jobright.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.welcometothejungle.com/*"],
      "js": ["content-scripts/wttj.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://jobs.ashbyhq.com/*",
        "https://*.ashbyhq.com/*"
      ],
      "js": ["content-scripts/ashby.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://jobs.recruitee.com/*",
        "https://*.recruitee.com/*"
      ],
      "js": ["content-scripts/recruitee.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/captcha-handler.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "JobAutoApply"
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["lib/*", "utils/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
