{
  "name": "huntflow-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend for HuntFlow MERN application with simple CRUD endpoints for jobs, applications, CVs, tracks and chat logs. All AI features have been removed.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --watch src --ext js,mjs,json --exec \"node src/server.js\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "connect-mongo": "^5.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
